<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="8.1-create-inventory-report-table" author="Wojtek">
        <createTable tableName="inventory_report">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="inventory_report"
                baseColumnNames="created_by"
                constraintName="fk_inventory_report_employee"
                referencedTableName="employee"
                referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="8.2-create-inventory-report-item-table" author="Wojtek">
        <createTable tableName="inventory_report_item">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="inventory_report_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="product_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="supply_before" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="supply_after" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="inventory_report_item"
                baseColumnNames="inventory_report_id"
                constraintName="fk_inventory_report_item_report"
                referencedTableName="inventory_report"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                baseTableName="inventory_report_item"
                baseColumnNames="product_id"
                constraintName="fk_inventory_report_item_product"
                referencedTableName="product"
                referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="8.3-rename-second-name-to-last-name" author="Wojtek">
        <renameColumn tableName="employee"
                      oldColumnName="second_name"
                      newColumnName="last_name"
                      columnDataType="VARCHAR(255)"/>
    </changeSet>

    <changeSet id="8.4-add-approved-to-inventory-report" author="Wojtek">
        <addColumn tableName="inventory_report">
            <column name="approved" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="8.5-create-bonus-params-snapshot-table" author="Wojtek">
        <createTable tableName="bonus_params_snapshot">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="employee_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="year" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="month" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="bonus_percent" type="DOUBLE PRECISION"/>
            <column name="sale_bonus_percent" type="DOUBLE PRECISION"/>
            <column name="boost_net_rate" type="DOUBLE PRECISION"/>
            <column name="bonus_threshold" type="DOUBLE PRECISION"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="bonus_params_snapshot"
                baseColumnNames="employee_id"
                constraintName="fk_bps_employee"
                referencedTableName="employee"
                referencedColumnNames="id"/>

        <addUniqueConstraint
                tableName="bonus_params_snapshot"
                columnNames="employee_id, year, month"
                constraintName="uq_bps_employee_period"/>
    </changeSet>

    <changeSet id="8.6-add-order-to-company-expense" author="Wojtek">
        <addColumn tableName="company_expense">
            <column name="order_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint
                baseTableName="company_expense"
                baseColumnNames="order_id"
                constraintName="fk_company_expense_order"
                referencedTableName="internal_order"
                referencedColumnNames="id"/>

        <addUniqueConstraint
                tableName="company_expense"
                columnNames="order_id"
                constraintName="uq_company_expense_order"/>
    </changeSet>

</databaseChangeLog>
