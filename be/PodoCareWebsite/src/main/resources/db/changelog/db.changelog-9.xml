<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="9.1-create-cash-ledger-table" author="Wojtek">
        <createTable tableName="cash_ledger">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="opening_amount" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>
            <column name="deposit" type="DOUBLE PRECISION" defaultValueNumeric="0.0">
                <constraints nullable="false"/>
            </column>
            <column name="closing_amount" type="DOUBLE PRECISION"/>
            <column name="cash_out_amount" type="DOUBLE PRECISION" defaultValueNumeric="0.0">
                <constraints nullable="false"/>
            </column>
            <column name="note" type="TEXT"/>
            <column name="created_by_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="closed_by_id" type="BIGINT"/>
            <column name="is_closed" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
                tableName="cash_ledger"
                columnNames="date"
                constraintName="uq_cash_ledger_date"/>

        <addForeignKeyConstraint
                baseTableName="cash_ledger"
                baseColumnNames="created_by_id"
                constraintName="fk_cash_ledger_created_by"
                referencedTableName="employee"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                baseTableName="cash_ledger"
                baseColumnNames="closed_by_id"
                constraintName="fk_cash_ledger_closed_by"
                referencedTableName="employee"
                referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
